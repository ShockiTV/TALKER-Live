-- TALKER WebSocket Integration Script
-- Drives bridge_channel.tick() via game timer,
-- shows HUD status notifications, and exposes the public publishing API.
-- All traffic flows through talker_bridge (port 5558) which proxies to talker_service.

package.path = package.path .. ";./bin/lua/?.lua;"
local logger  = require("framework.logger")
local config  = require("interface.config")
local keycloak_client = require("infra.auth.keycloak_client")

-- Register custom callbacks so SendScriptCallback can find them
AddScriptCallback("publish_game_event_v2")

-- Single WS channel to talker_bridge
local bridge_channel  = nil
local is_initialized  = false

local tick_timer_id     = "talker_ws_tick"

-- Service status tracking (for HUD notifications)
local last_known_status   = "disconnected"
local notified_disconnect = false
local SERVICE_TIMEOUT_SECONDS = 15

--------------------------------------------------------------------------------
-- Helpers
--------------------------------------------------------------------------------

local function safe_require(module_name)
    local ok, mod = pcall(require, module_name)
    if ok then
        return mod
    else
        logger.debug("Could not load module: " .. module_name .. " - " .. tostring(mod))
        return nil
    end
end

local function append_query_token(url, token)
    if token == "" then
        return url
    end
    local sep = url:find("?") and "&" or "?"
    return url .. sep .. "token=" .. token
end

local function derive_token_url(service_url)
    if type(service_url) ~= "string" or service_url == "" then
        return nil
    end

    local scheme, remainder = service_url:match("^(%a+)%:%/%/(.+)$")
    if not scheme or not remainder then
        return nil
    end

    local authority = remainder:match("^([^/%?]+)")
    if not authority or authority == "" then
        return nil
    end

    local token_scheme = scheme
    if scheme == "ws" then
        token_scheme = "http"
    elseif scheme == "wss" then
        token_scheme = "https"
    end

    return token_scheme .. "://" .. authority .. "/auth/realms/talker/protocol/openid-connect/token"
end

local function trim(value)
    if type(value) ~= "string" then
        return ""
    end
    return value:gsub("^%s+", ""):gsub("%s+$", "")
end

local function get_auth_config_values()
    local client_id = trim(config.auth_client_id and config.auth_client_id() or "")
    local client_secret = trim(config.auth_client_secret and config.auth_client_secret() or "")
    local username = trim(config.auth_username and config.auth_username() or "")
    local password = config.auth_password and config.auth_password() or ""
    return client_id, client_secret, username, password
end

local function is_ropc_auth_configured()
    local client_id, _, username, password = get_auth_config_values()
    return client_id ~= "" and username ~= "" and password ~= ""
end

local function configure_keycloak_client()
    local client_id, client_secret, username, password = get_auth_config_values()
    local service_url = config.service_url and config.service_url() or "ws://127.0.0.1:5557/ws"
    local token_url = derive_token_url(service_url)

    if not token_url then
        keycloak_client.clear()
        return false
    end

    keycloak_client.configure(token_url, client_id, username, password, client_secret)
    return token_url ~= "" and client_id ~= "" and username ~= "" and password ~= ""
end

local function get_service_url()
    local url = config.service_url and config.service_url() or "ws://127.0.0.1:5557/ws"

    if is_ropc_auth_configured() then
        local token = keycloak_client.get_cached_token()
        if not token then
            local fetched, err = keycloak_client.fetch_token()
            token = fetched
            if not token and err then
                logger.warn("Keycloak token fetch failed while building service URL: %s", tostring(err))
            end
        end
        if token and token ~= "" then
            return append_query_token(url, token)
        end
    end

    return url
end

function build_service_url()
    return get_service_url()
end

local function get_ws_connect_options()
    -- pollnet WS does not support custom headers;
    -- auth token is appended as ?token= query param in get_service_url()
    return nil
end

function build_ws_connect_options()
    return get_ws_connect_options()
end

local function get_session_id_from_persistence()
    if talker_game_persistence and talker_game_persistence.get_session_id then
        return talker_game_persistence.get_session_id()
    end
    if type(_G.get_session_id) == "function" then
        return _G.get_session_id()
    end
    return nil
end

function build_config_sync_payload()
    local all_config = config.get_all_config()
    local session_id = get_session_id_from_persistence()
    if session_id and session_id ~= "" then
        all_config.session_id = session_id
    end
    return all_config
end

--------------------------------------------------------------------------------
-- Initialization
--------------------------------------------------------------------------------

local function init_channels()
    if is_initialized then
        return bridge_channel ~= nil
    end
    is_initialized = true

    bridge_channel = safe_require("infra.bridge.channel")
    if not bridge_channel then
        logger.warn("bridge_channel module not available - WS integration disabled")
        return false
    end

    configure_keycloak_client()

    bridge_channel.init(get_service_url, get_ws_connect_options())
    bridge_channel.set_before_connect(function()
        local enabled = configure_keycloak_client()
        if not enabled then
            return
        end

        -- Prime the token cache before the URL is built: get_service_url() calls
        -- get_cached_token() first, so fetching here ensures a fresh token is ready.
        local token, err = keycloak_client.fetch_token()
        if not token and err then
            logger.warn("Keycloak token refresh failed before WS connect: %s", tostring(err))
        end
    end)

    -- On reconnect, resend full config sync
    bridge_channel.set_on_reconnect(function()
        logger.info("WS reconnected - sending config sync")
        publish_config_sync()
    end)

    local init_url = get_service_url()
    logger.warn("WS service channel initialized (url=%s)", init_url)
    if is_ropc_auth_configured() then
        logger.warn("ROPC auth enabled (client_id=%s, username=%s)",
            trim(config.auth_client_id and config.auth_client_id() or ""),
            trim(config.auth_username and config.auth_username() or ""))
    else
        logger.info("ROPC auth disabled (no credentials configured)")
    end
    start_tick_timer()
    return true
end

local function shutdown_channels()
    stop_tick_timer()
    if bridge_channel then
        bridge_channel.shutdown()
    end
    bridge_channel   = nil
    is_initialized   = false
end

--------------------------------------------------------------------------------
-- Tick Timer â€” drives both channels
--------------------------------------------------------------------------------

local function tick()
    if bridge_channel then
        bridge_channel.tick()
    end
    -- Drain native audio DLL ring buffer (no-op when DLL absent)
    local audio_tick = safe_require("infra.mic.audio_tick")
    if audio_tick then
        audio_tick.tick()
    end
    return false -- continue timer
end

function start_tick_timer()
    local interval = 0.05  -- 50ms (20 ticks/sec) â€” responsive without being wasteful
    CreateTimeEvent(tick_timer_id, tick_timer_id, interval, function()
        tick()
        ResetTimeEvent(tick_timer_id, tick_timer_id, interval)
        return false
    end)
end

function stop_tick_timer()
    RemoveTimeEvent(tick_timer_id, tick_timer_id)
end



--------------------------------------------------------------------------------
-- Service Status Notifications
--------------------------------------------------------------------------------

local function show_service_disconnected_notification()
    if db and db.actor then
        local msg = game.translate_string("ui_mcm_talker_service_disconnected")
        if msg == "ui_mcm_talker_service_disconnected" then
            msg = "TALKER: Python service not responding. AI dialogue disabled."
        end
        actor_menu.set_msg(1, msg, 7)
        logger.warn("Python service disconnected - showed HUD notification")
    end
end

local function show_service_reconnected_notification()
    if db and db.actor then
        local msg = game.translate_string("ui_mcm_talker_service_reconnected")
        if msg == "ui_mcm_talker_service_reconnected" then
            msg = "TALKER: Python service reconnected. AI dialogue restored."
        end
        actor_menu.set_msg(1, msg, 5)
        logger.info("Python service reconnected - showed HUD notification")
    end
end

local function update_status_notifications()
    if not bridge_channel then return end

    local status = bridge_channel.get_status()
    if status ~= last_known_status then
        if last_known_status == "connected" and status ~= "connected" then
            -- Just disconnected
            if not notified_disconnect then
                show_service_disconnected_notification()
                notified_disconnect = true
            end
        elseif status == "connected" and last_known_status ~= "connected" then
            -- Just reconnected
            if notified_disconnect then
                show_service_reconnected_notification()
                notified_disconnect = false
            end
        end
        last_known_status = status
    end
end

--------------------------------------------------------------------------------
-- Command Handler Registration (for command/query handler scripts)
--------------------------------------------------------------------------------

--- Register a handler for receiving commands from Python.
-- Delegates to bridge_channel.on(topic, handler).
-- @param topic   string    Topic (e.g. "dialogue.display")
-- @param handler function  fn(payload, request_id)
function register_command_handler(topic, handler)
    if not init_channels() then
        logger.warn("Cannot register command handler - WS not initialized")
        return false
    end
    bridge_channel.on(topic, handler)
    return true
end

--------------------------------------------------------------------------------
-- Public API (for use by other scripts)
--------------------------------------------------------------------------------

--- Get the service channel module (for scripts that need direct access).
function get_service_channel()
    if not init_channels() then return nil end
    return bridge_channel
end

--- Backward-compatible alias for get_service_channel.
-- Mic-related topics are now also routed through the service channel.
function get_mic_channel()
    return get_service_channel()
end

function publish_game_event(event, is_important)
    if not init_channels() then return false end

    if bridge_channel.get_status() ~= "connected" then
        -- Queue will hold it, but warn if offline
        logger.debug("WS not connected - event queued")
    end

    -- Use the serializer to transform the event for the wire
    local serializer = require("infra.ws.serializer")
    local payload = serializer.serialize_event(event)
    payload.is_important = is_important

    bridge_channel.publish("game.event", payload)
    return true
end

--- Publish game event (v2 format) with candidates, world, and traits.
-- New unified format for tools-based-memory architecture.
-- @param event       Event object
-- @param candidates  Array of Character objects
-- @param world       World description string
-- @param traits      Traits map {character_id â†’ {personality_id, backstory_id}}
function publish_game_event_v2(event, candidates, world, traits)
    if not init_channels() then return false end

    if bridge_channel.get_status() ~= "connected" then
        logger.debug("WS not connected - event queued")
    end

    -- Use the serializer to build the v2 payload
    local serializer = require("infra.ws.serializer")
    local payload = serializer.serialize_game_event_v2(event, candidates, world, traits)

    bridge_channel.publish("game.event", payload)
    return true
end

function publish_player_dialogue(text, context)
    if not init_channels() then return false end

    local serializer = require("infra.ws.serializer")
    local payload = {
        text = text,
        context = context and serializer.serialize_context(context) or {},
    }
    bridge_channel.publish("player.dialogue", payload)
    return true
end

function publish_player_whisper(text, target)
    if not init_channels() then return false end

    local serializer = require("infra.ws.serializer")
    local payload = {
        text = text,
    }
    if target then
        payload.target = serializer.serialize_character(target)
    end
    bridge_channel.publish("player.whisper", payload)
    return true
end

function publish_config_update(key, value)
    if not init_channels() then return false end
    bridge_channel.publish("config.update", { key = key, value = value })
    return true
end

function publish_config_sync()
    if not init_channels() then return false end
    local all_config = build_config_sync_payload()
    bridge_channel.publish("config.sync", all_config)
    return true
end

function is_ws_connected()
    return bridge_channel ~= nil and bridge_channel.get_status() == "connected"
end

--------------------------------------------------------------------------------
-- Game Callbacks
--------------------------------------------------------------------------------

local function on_game_load()
    logger.info("WS integration: on_game_load")

    if init_channels() then
        -- Send full config sync after a short delay
        CreateTimeEvent("ws_config_sync", "initial_sync", 2, function()
            publish_config_sync()
            return true -- one-shot
        end)
    end
end

local function on_game_save()
    -- Placeholder for future save-time logic (heartbeat removed per design)
end

local function on_game_end()
    logger.info("WS integration: on_game_end")
    shutdown_channels()
end

local function on_mcm_changed()
    logger.debug("WS integration: MCM settings changed")
    publish_config_sync()
end

-- Periodic status update (runs inside tick)
local status_check_counter = 0
local STATUS_CHECK_INTERVAL = 100 -- every 100 ticks â‰ˆ 5s

local original_tick = tick
tick = function()
    original_tick()
    status_check_counter = status_check_counter + 1
    if status_check_counter >= STATUS_CHECK_INTERVAL then
        status_check_counter = 0
        update_status_notifications()
    end
end

--------------------------------------------------------------------------------
-- Registration
--------------------------------------------------------------------------------

function on_game_start()
    RegisterScriptCallback("on_game_load", on_game_load)
    RegisterScriptCallback("save_state", on_game_save)
    RegisterScriptCallback("actor_on_net_destroy", on_game_end)
    RegisterScriptCallback("publish_game_event_v2", publish_game_event_v2)

    if ui_mcm and ui_mcm.register_callback then
        ui_mcm.register_callback("talker", on_mcm_changed)
    end

    logger.info("WS integration script registered")
end

function is_loaded()
    return true
end
