-- Function to retrieve the configuration value
-- Trigger keys (triggers/...) map to talker/triggers/..., all others to talker/general/...
function get(key)
    if ui_mcm then
        if key:sub(1, 9) == "triggers/" then
            return ui_mcm.get("talker/" .. key)
        else
            local value = ui_mcm.get("talker/general/" .. key)
            if key == "service_url" then
                printf("[TALKER] MCM service_url = %s (type=%s)", tostring(value), type(value))
            end
            return value
        end
    end
    if key == "service_url" then
        printf("[TALKER] MCM unavailable, service_url default = %s", tostring(defaults[key]))
    end
    return defaults[key]
end
