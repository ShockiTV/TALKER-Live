local function get_mcm_value_from_paths(key, prefixes)
    for _, prefix in ipairs(prefixes) do
        local value = ui_mcm.get(prefix .. key)
        if value ~= nil then
            return value
        end
    end
    return nil
end

-- Function to retrieve the configuration value
function get(key)
    if ui_mcm then
        if key:sub(1, 9) == "triggers/" then
            local trigger_paths = {
                "talker/triggers_subtab/",
                "talker/triggers/",
            }
            local value = get_mcm_value_from_paths(key, trigger_paths)
            if value ~= nil then
                return value
            end
        else
            local common_paths = {
                "talker/general_subtab/",
                "talker/ai_model_subtab/",
                "talker/voice_subtab/",
                "talker/connection_subtab/",
                "talker/triggers_subtab/",
                "talker/debug_subtab/",
                "talker/general/",
            }
            local value = get_mcm_value_from_paths(key, common_paths)
            if value ~= nil then
                return value
            end
        end
    end

    return defaults[key]
end
