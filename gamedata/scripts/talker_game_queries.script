--------------------------------------------------------------------------------
-- XML Loading
--------------------------------------------------------------------------------

-- Load a translated string from the game's XML files.
function load_xml(input)
    if not input then return "" end
    local key = "talker_" .. input
    local result = game.translate_string(key)
    if result == key then
        -- Try without prefix as a fallback
        result = game.translate_string(input)
        if result == input then
            log.debug("Translation not found for " .. input)
            return ""
        end
    end
    return result == "talkerIgnore" and "" or result
end

-- Load a random XML translation based on a given input
function load_random_xml(input)
    local translations = {}
    local baseKey = "talker_" .. input

    -- try numbered keys first (talker_<input>_1, _2, ...)
    local i = 1
    while true do
        local key = baseKey .. "_" .. i
        local translation = game.translate_string(key)
        if translation == key then break end
        translations[#translations+1] = translation
        i = i + 1
    end

    -- if none found, try the un-numbered talker_<input> key
    if #translations == 0 then
        local t = game.translate_string(baseKey)
        if t ~= baseKey then
            translations[#translations+1] = t
        end
    end

    if #translations > 0 then
        return translations[math.random(1, #translations)]
    else
        log.debug("no xml found for " .. input)
    end
end

-- HUD

function display_hud_message(message)
    actor_menu.set_msg(1, message, 7) -- 7 seconds, up from 3
end

-- SOUND

function play_sound(sound_name)
    xr_sound.set_sound_play(AC_ID, sound_name)
end

