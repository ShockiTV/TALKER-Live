function send_news_tip(sender_name, message, image, showtime)
    db.actor:give_game_news(sender_name, message, image, 0, showtime)
end







--------------------------------------------------------------------------------
-- UNIQUE NPCS — data now lives in domain/data/unique_npcs.lua
--------------------------------------------------------------------------------
-- Kept as a global for backward compat; delegate to the domain module.
function Set(t)
    return utils.Set(t)
end

-- important_npcs alias preserved so any callers that still use it directly continue to work.
local important_npcs = unique_npcs.ids

-- NPC ID list extracted to bin/lua/domain/data/unique_npcs.lua

function is_unique_character_by_id(npc_id)
    local npc = try(get_obj_by_id, npc_id) -- Use try to avoid error on nil

    if npc then
        if is_player(npc) then return true end
        if not (is_stalker(npc) or is_trader(npc)) then return false end
        local technical_name = get_technical_name(npc)
        return unique_npcs.is_unique(technical_name)
    end

    -- Fallback for offline characters
    local se_obj = alife():object(tonumber(npc_id))
    if se_obj and IsStalker(nil, se_obj:clsid()) then
        -- For server objects, use section_name()
        local technical_name = se_obj:section_name()
        return unique_npcs.is_unique(technical_name)
    end

    return false
end

function get_unique_character_personality(npc_id)
    local npc = get_obj_by_id(npc_id)
    if not npc then return nil end
    local technical_name = get_technical_name(npc)
    if not unique_npcs.is_unique(technical_name) then return nil end
end

--------------------------------------------------------------------------------
-- WORLD DESCRIPTION
--------------------------------------------------------------------------------

function get_time_scope(EventDate, scope)
    local Y, M, D, h, mint, sec, ms = EventDate:get()
    local tbl = {Y, M, D, h, mint, sec, ms}
    return tbl[scope]
end


-- Delegates to interface/world_description.lua (pure string assembly)
function describe_current_time()
    local hrs = get_time_scope(game.get_game_time(), 4)
    return world_desc.time_of_day(hrs)
end

function describe_emission()
    return world_desc.describe_emission(is_psy_storm_ongoing(), is_surge_ongoing())
end

function describe_weather()
    local weather_manager = level_weathers.get_weather_manager()
    local raw_weather     = weather_manager:get_curr_weather()
    return world_desc.describe_weather(raw_weather, describe_emission())
end

function describe_shelter(speaker, listener)
    if not is_player(speaker) and not is_player(listener) then return "" end
    return world_desc.describe_shelter(level.rain_factor(), level.rain_hemi())
end

function describe_world(speaker, listener)
    local location_name = get_nearby_smart_terrain_name(speaker) or get_location_name()
    local result = world_desc.build_description({
        location    = location_name,
        time_of_day = describe_current_time(),
        weather     = describe_weather(),
        shelter     = describe_shelter(speaker, listener),
        campfire    = get_nearby_campfire_status(speaker),
    })
    log.info("Dialogue Context: " .. result)
    return result
end


------------------------------------------------------------------------------------
-- TIME
------------------------------------------------------------------------------------

function delay(eventId, actionId, seconds, func, ...)
    CreateTimeEvent(eventId, actionId, seconds, func, ...)
end

function reset_delay(event_id, act_id, seconds)
    ResetTimeEvent(event_id, act_id, seconds)
end


-- since time global only counts from the last save, we need to keep adding to it
-- The accumulator is persisted via the timers store (domain.repo.timers)
function get_game_time_ms()
    return time_global() + timers.get_game_time_accumulator()
end

--------------------------------------------------------------------------------
-- Load check
--------------------------------------------------------------------------------

function is_loaded()
    return true
end



