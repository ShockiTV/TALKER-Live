---@diagnostic disable: undefined-global
package.path = package.path .. ";./bin/lua/?.lua;"

local trigger    = require("interface.trigger")
local EventType  = trigger.EventType
local game       = require("infra.game_adapter")
local log        = require("framework.logger")
local config     = require("interface.config")
local chance     = require("domain.service.chance")
local importance = require("domain.service.importance")
local timers     = require("domain.repo.timers")

local queries    = talker_game_queries

-- Manual cooldown timer (idle needs special reset behavior on combat/sleep)
local last_idle_time_ms = 0

---------------------------------------------------------------------------------------------
-- WEATHER MODE DETECTION
--------------------------------------------------------------------------------------------

--- Detect the active weather mode for idle conversations.
-- @return "during_psy_storm", "during_emission", or nil (base mode)
local function get_weather_mode()
    if psi_storm_manager and psi_storm_manager.get_surge_manager then
        local sm = psi_storm_manager.get_surge_manager()
        if sm and sm.started then return "during_psy_storm" end
    end
    if surge_manager and surge_manager.get_surge_manager then
        local sm = surge_manager.get_surge_manager()
        if sm and sm.started then return "during_emission" end
    end
    return nil
end

--- Get the enable, cooldown, and chance keys for the current idle sub-mode.
local function get_idle_settings()
    local mode = get_weather_mode()
    if mode then
        return {
            enable   = "triggers/idle/enable_" .. mode,
            cooldown = "triggers/idle/cooldown_" .. mode,
            chance   = "triggers/idle/chance_" .. mode,
        }
    end
    return {
        enable   = "triggers/idle/enable",
        cooldown = "triggers/idle/cooldown",
        chance   = "triggers/idle/chance",
    }
end

---------------------------------------------------------------------------------------------
-- CONDITIONS
--------------------------------------------------------------------------------------------

local function cooldown_ready(cooldown_ms)
    return queries.get_game_time_ms() - last_idle_time_ms > cooldown_ms
end

local function shuffle(tbl)
    for i = #tbl, 2, -1 do
        local j = math.random(i)
        tbl[i], tbl[j] = tbl[j], tbl[i]
    end
end

---------------------------------------------------------------------------------------------
-- IDLE CONVERSATION
--------------------------------------------------------------------------------------------
function on_every_10_seconds()
    local settings = get_idle_settings()
    if not config.get(settings.enable) then return end

    if not db.actor then return end

    -- Reset cooldown if player is in combat or sleeping (prevents idle right after)
    local is_player_in_combat = #queries.get_enemies_fighting_player() ~= 0
    if is_player_in_combat or db.actor:has_info("actor_is_sleeping") then
        last_idle_time_ms = queries.get_game_time_ms()
        return
    end

    local cooldown_ms = config.get(settings.cooldown) * 1000
    if not cooldown_ready(cooldown_ms) then return end

    local all_candidates = game.get_characters_near_player()
    if not all_candidates or #all_candidates == 0 then return end

    -- Filter out invalid candidates (player, those in combat)
    local valid_candidates = {}
    for _, npc in ipairs(all_candidates) do
        local npc_obj = queries.get_obj_by_id(npc.game_id)
        if npc_obj and not queries.is_player(npc_obj) and not queries.is_in_combat(npc_obj) then
            valid_candidates[#valid_candidates+1] = npc_obj
        end
    end

    if #valid_candidates == 0 then return end

    shuffle(valid_candidates)

    for _, npc_obj in ipairs(valid_candidates) do
        local speaker_name = queries.get_name(npc_obj)
        local speaker_character = game.create_character(npc_obj)

        local context = {
            actor = speaker_character,
            instruction = string.format("%s begins an idle conversation to pass the time.", speaker_name)
        }
        local witnesses = { speaker_character }

        -- NPC-driven event: importance of speaker or chance
        local speaker_flags = {
            is_player    = false,
            is_companion = queries.is_companion(npc_obj),
            is_unique    = queries.is_unique_character_by_id(npc_obj:id()),
            rank         = queries.get_rank(npc_obj),
        }

        if importance.is_important_person(speaker_flags) or chance.check(settings.chance) then
            trigger.publish_event(EventType.IDLE, context, witnesses)
        else
            trigger.store_event(EventType.IDLE, context, witnesses)
        end

        log.debug("TALKER: Idle chatter triggered for " .. speaker_name)
        break
    end

    -- Reset cooldown after attempt (whether succeeded or failed)
    last_idle_time_ms = queries.get_game_time_ms()
end

--------------------------------------------------------------------------------------------
-- Set up
--------------------------------------------------------------------------------------------

local function safe_on_every_10_seconds()
    local status, err = pcall(on_every_10_seconds)
    if not status then
        log.error("Error in safe_on_every_10_seconds: " .. err)
    end
end

-- 10-second polling interval
local CHECK_INTERVAL_MS = 10 * 1000
local function on_every_ms()
    if queries.get_game_time_ms() - timers.get_idle_last_check_time() < CHECK_INTERVAL_MS then return end
    timers.set_idle_last_check_time(queries.get_game_time_ms())
    safe_on_every_10_seconds()
end

function on_game_start()
    -- Reset the idle conversation cooldown to the current game time upon loading.
    last_idle_time_ms = queries.get_game_time_ms()
    RegisterScriptCallback("actor_on_update", on_every_ms)
end

function is_loaded()
    return true
end
