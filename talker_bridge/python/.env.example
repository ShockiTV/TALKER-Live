# ─────────────────────────────────────────────────────────────────
# TALKER Bridge — Environment Configuration
# 
# Load via .env or .env.local (using python-dotenv)
#
# SERVER-AUTHORITY PIN:
#   When SERVICE_WS_URL is set (not empty), it PINS the upstream service URL.
#   MCM config.sync cannot override a pinned URL.
#   This matches the pin pattern in talker_service (LLM_PROVIDER, LLM_MODEL, etc.)
# ─────────────────────────────────────────────────────────────────

# WebSocket URL to upstream talker_service
# When set, this PIN overrides MCM settings (server authority).
# Leave empty to allow MCM to control the URL at runtime.
# 
# Examples:
#   wss://talker-live.duckdns.org/ws    (VPS default)
#   ws://127.0.0.1:5557/ws              (local dev with SSH tunnel)
SERVICE_WS_URL=wss://talker-live.duckdns.org/ws

# Optional: auth token appended as query parameter
# WS_TOKEN=your-auth-token

# Bridge log verbosity (INFO or DEBUG)
# Set DEBUG during troubleshooting to capture topic-forwarding details.
# BRIDGE_LOG_LEVEL=DEBUG
# Normal run:
# BRIDGE_LOG_LEVEL=INFO

