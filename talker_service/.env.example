# TALKER Service Configuration
# Copy this file to .env and customize as needed

# Service Settings (WS + HTTP on same port)
WS_HOST=127.0.0.1
WS_PORT=5557

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/talker_service.log
# LOG_HEARTBEAT=false  # Set to true to log heartbeat messages (verbose)
# Troubleshooting preset:
#   LOG_LEVEL=DEBUG
#   LOG_HEARTBEAT=true

# TTS - In-engine NPC audio generation
# TTS_ENABLED=true
# VOICES_DIR=./voices

# STT - Local Whisper model (requires [stt] extra)
# WHISPER_MODEL=base.en
# WHISPER_BEAM_SIZE=1

# ── Server Authority Pins ──────────────────────────────────────
# When set, these override MCM values. Omit to let MCM control.
# LLM_PROVIDER=openai             # openai | openrouter | ollama | proxy
# LLM_MODEL=gpt-4o                # pins model_name (dialogue generation)
# LLM_MODEL_FAST=gpt-4o-mini      # pins model_name_fast (speaker selection)
# OPENAI_ENDPOINT=                 # custom endpoint (Azure, GitHub Models, etc.)
# STT_METHOD=local                 # local | api | proxy

# ── Backward Compat (legacy, prefer the keys above) ───────────
# FORCE_PROXY_LLM=true            # same as LLM_PROVIDER=proxy
# FORCE_LOCAL_WHISPER=true         # same as STT_METHOD=local

# Proxy LLM settings (used when LLM_PROVIDER=proxy or FORCE_PROXY_LLM=true)
# PROXY_MODEL="gpt-4o"
# PROXY_ENDPOINT="https://models.inference.ai.azure.com/chat/completions"
# PROXY_API_KEY="your-github-pat-here"
