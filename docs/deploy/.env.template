# ─────────────────────────────────────────────────────────────────
# TALKER Service — per-branch environment file
#
# Copy this file to .env.<branch> (e.g. .env.main, .env.dev) and
# fill in the values.  Each branch instance loads its own .env file.
#
# Fields marked [per-branch] differ per instance.
# Fields marked [shared] are typically the same across branches.
# ─────────────────────────────────────────────────────────────────

# ─── Domain [shared] ──────────────────────────────────────────
DOMAIN=talker.yourdomain.com

# ─── Auth Tokens [per-branch] ─────────────────────────────────
# Format: name:token,name:token
# Each branch can have its own set of invite codes.
TALKER_TOKENS=player1:invite-code-abc123,player2:invite-code-def456

# ─── LLM API Keys [shared or per-branch] ─────────────────────
# Set whichever providers you use.  Can differ per branch if
# testing different providers.
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...

# ─── Server Authority Pins [per-branch] ───────────────────────
# These override MCM settings from the game client.
# Useful for locking a branch to a specific provider/model.
#
# LLM_PROVIDER=openai        # openai | openrouter | ollama | proxy
# LLM_MODEL=gpt-4o           # pins model_name (MCM cannot override)
# LLM_MODEL_FAST=gpt-4o-mini # pins model_name_fast
# STT_METHOD=api              # local | api | proxy

# ─── Remote TTS/STT [shared] ─────────────────────────────────
# These are set in docker-compose.yml environment, not here.
# Listed for reference only:
# TTS_SERVICE_URL=http://tts-service:8100
# STT_ENDPOINT=http://stt-service:8000/v1

# ─── Grafana [shared] ────────────────────────────────────────
GRAFANA_PASSWORD=your-secure-grafana-password
